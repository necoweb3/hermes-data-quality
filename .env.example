PORT=3100

# Fallback key used when a model-specific key is not provided.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Hosted NVIDIA Build model ids.
NVIDIA_SAFETY_MODEL=nvidia/nemotron-3-content-safety
NVIDIA_POLICY_MODEL=nvidia/nemotron-content-safety-reasoning-4b
NVIDIA_PII_MODEL=nvidia/gliner-pii
NVIDIA_ASR_MODEL=nvidia/parakeet-tdt-0.6b-v2
NVIDIA_ASR_FUNCTION_ID=d3fe9151-442b-4204-a70d-5fcc597fd610
NVIDIA_NVCLIP_MODEL=nvidia/nvclip
NVIDIA_ACTIVE_SPEAKER_MODEL=nvidia/active-speaker-detection
NVIDIA_VISION_MODEL=
NVIDIA_SYNTHETIC_VIDEO_MODEL=

# Optional model-specific keys. Use these when Build issues a separate key per model.
NVIDIA_SAFETY_API_KEY=
NVIDIA_POLICY_API_KEY=
NVIDIA_PII_API_KEY=
NVIDIA_ASR_API_KEY=
NVIDIA_NVCLIP_API_KEY=
NVIDIA_ACTIVE_SPEAKER_API_KEY=
NVIDIA_VISION_API_KEY=
NVIDIA_SYNTHETIC_VIDEO_API_KEY=

# ASR bridge. Parakeet hosted API uses NVIDIA Riva gRPC. Use WSL when Python is
# installed there instead of Windows.
ASR_RUNNER=wsl
ASR_WSL_DISTRO=Ubuntu-22.04
ASR_SERVER=grpc.nvcf.nvidia.com:443
ASR_LANGUAGE_CODE=en-US
ASR_TIMEOUT_MS=120000
ASR_PYTHON_COMMAND=python

# Optional paid/credit-based Bitdeer vision endpoint for models that are not
# available as NVIDIA hosted free endpoints.
BITDEER_API_KEY=
BITDEER_BASE_URL=https://api-inference.bitdeer.ai/v1
BITDEER_VISION_MODEL=nvidia/NVIDIA-Nemotron-Nano-12B-v2-VL
